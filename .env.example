APP_NAME="APO Box Account"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Indiana/Indianapolis
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=apobox
DB_USERNAME=apobox
DB_PASSWORD=secret

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.apobox.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=apobox

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=admin@apobox.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="no-reply@apobox.com"
MAIL_FROM_NAME="APO Box"

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# Security
CREDIT_CARD_KEY=testkey
ADMIN_ALLOWED_IPS=192.168.1.33

# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost/admin/login-google

# Shipping: FedEx
FEDEX_KEY=
FEDEX_PASSWORD=
FEDEX_ACCOUNT=
FEDEX_METER=

# Shipping: USPS
USPS_USER_ID=

# Shipping: Endicia
ENDICIA_ACCOUNT_NUMBER=
ENDICIA_CUSTOMS_SIGNER=

# Zebra Label Printer
ZEBRA_PRINT_METHOD=raw
ZEBRA_PRINTER_IP=
ZEBRA_AUTO_PRINT=false
