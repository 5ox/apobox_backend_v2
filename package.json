{
  "name": "apobox-account",
  "private": true,
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "build:email": "node scripts/build-email.js",
    "build:widget": "node scripts/build-widget.js",
    "build:app": "cd chrome_app && zip -r apobox_scale.zip *.js *.json *.html *.png",
    "build:all": "npm run build && npm run build:email && npm run build:widget && npm run build:app"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.3",
    "chart.js": "^4.4.7"
  },
  "devDependencies": {
    "juice": "^11.0.0",
    "sass": "^1.83.0",
    "vite": "^6.0.0"
  }
}
