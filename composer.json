{
  "name": "loadsys/apo-box-account",
  "description": "APO Box account management app",
  "license": "proprietary",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
    "php": ">=5.6.0",
    "cakephp/cakephp": "2.9.*",
    "cakephp/debug_kit": "2.2.*",
    "loadsys/cakephp-shell-scripts": "2.1.*",
    "paypal/rest-api-sdk-php": "1.*",
    "inacho/php-credit-card-validator": "1.*",
    "loadsys/cakephp_serializers": "1.0.*",
    "robgridley/zebra": "1.0.*",
    "league/oauth2-google": "^1.0",
    "dereuromark/cakephp-queue": "2.3.*"
  },
  "require-dev": {
    "johnkary/phpunit-speedtrap": "^1.0"
  },
  "config": {
    "vendor-dir": "Vendor/",
    "bin-dir": "bin",
    "github-oauth": {
      "github.com": "ad2c41a52ec64b6de048bbf4a5de3a808ae3e8b8"
    }
  },
  "scripts": {
    "check": [
      "bin/phpcs -p --extensions=php --standard=Vendor/loadsys/loadsys_codesniffer/Loadsys --report-full --report-summary ./Controller ./Model ./View ./Lib ./Console/Command"
    ]
  }
}
